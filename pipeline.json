{
  "pipeline": {
    "name": "6-Agent Video Production Workflow",
    "version": "1.0.0",
    "description": "Orchestrates 6 agents to produce a news broadcast video from Horizon data"
  },
  "phases": {
    "phase1": {
      "name": "Parallel Content Processing",
      "agents": [
        "agent1",
        "agent2",
        "agent3"
      ],
      "run_mode": "parallel",
      "description": "Process Horizon data, generate broadcast scripts, and set up Remotion video"
    },
    "phase2": {
      "name": "Aesthetic Review Loop",
      "agents": [
        "agent3",
        "agent4"
      ],
      "run_mode": "loop",
      "max_iterations": 3,
      "description": "Review Remotion video quality, loop back with feedback if needed"
    },
    "phase3": {
      "name": "Video Assembly",
      "agents": [
        "agent5"
      ],
      "run_mode": "sequential",
      "description": "Agent 5 validates story MP4s and concatenates into final broadcast video"
    },
    "phase4": {
      "name": "Final Review",
      "agents": [
        "agent6"
      ],
      "run_mode": "sequential",
      "max_iterations": 0,
      "description": "Agent 6 runs comprehensive final review and packages final output"
    }
  },
  "agents": {
    "agent1": {
      "name": "Horizon Content Processor",
      "domain": "D:\\claude_demo\\Horizon",
      "role": "Process enriched news data and extract structured outputs",
      "inputs": [
        {
          "path": "Horizon/data/enriched/{date}.json",
          "format": "json",
          "description": "AI-enriched news items from Horizon aggregation system"
        },
        {
          "path": "Horizon/data/summaries/horizon-{date}-{lang}.md",
          "format": "markdown",
          "description": "AI-generated daily summaries"
        }
      ],
      "outputs": [
        {
          "path": "Horizon/output/daily-digest-{date}.md",
          "format": "markdown",
          "consumed_by": [
            "agent2",
            "agent3",
            "agent5"
          ]
        },
        {
          "path": "Horizon/output/simplified-{date}.json",
          "format": "json",
          "consumed_by": [
            "agent3",
            "agent5"
          ]
        },
        {
          "path": "Horizon/output/category-statistics-{date}.md",
          "format": "markdown",
          "consumed_by": [
            "agent5"
          ]
        },
        {
          "path": "Horizon/output/ai-score-ranking-{date}.md",
          "format": "markdown",
          "consumed_by": [
            "agent2",
            "agent5"
          ]
        }
      ]
    },
    "agent2": {
      "name": "Broadcast Engine Processor",
      "domain": "D:\\claude_demo\\broadcast-engine",
      "role": "Generate broadcast scripts from Horizon enriched news data",
      "inputs": [
        {
          "path": "Horizon/data/enriched/{date}.json",
          "format": "json",
          "source": "Horizon / Agent 1"
        }
      ],
      "outputs": [
        {
          "path": "broadcast-engine/output/{date}-script.md",
          "format": "markdown",
          "consumed_by": [
            "agent3",
            "agent5"
          ]
        },
        {
          "path": "broadcast-engine/output/{date}-script-en.md",
          "format": "markdown",
          "consumed_by": [
            "agent3",
            "agent5"
          ]
        }
      ]
    },
    "agent3": {
      "name": "Remotion Video Producer",
      "domain": "D:\\claude_demo\\remotion-product",
      "role": "Create Remotion video with seendance effects using news data",
      "inputs": [
        {
          "path": "Horizon/output/simplified-{date}.json",
          "format": "json",
          "source": "Agent 1"
        },
        {
          "path": "broadcast-engine/output/{date}-script.md",
          "format": "markdown",
          "source": "Agent 2"
        }
      ],
      "outputs": [
        {
          "path": "remotion-product/output/broadcast.mp4",
          "format": "video/mp4",
          "consumed_by": [
            "agent4"
          ]
        }
      ],
      "review_feedback_input": {
        "path": "remotion-product/review-report.md",
        "format": "markdown",
        "source": "Agent 4"
      }
    },
    "agent4": {
      "name": "Aesthetic Reviewer",
      "role": "Review video quality and provide aesthetic feedback",
      "inputs": [
        {
          "path": "remotion-product/output/broadcast.mp4",
          "format": "video/mp4",
          "source": "Agent 3"
        }
      ],
      "outputs": [
        {
          "path": "remotion-product/review-report.md",
          "format": "markdown",
          "consumed_by": [
            "agent3"
          ]
        }
      ]
    },
    "agent5": {
      "name": "Video Assembler",
      "domain": "D:\\claude_demo\u0007gent5-video-assembler",
      "role": "Validate per-story MP4s and concatenate into final broadcast video",
      "inputs": [
        {
          "path": "remotion-product/output/story-{0..5}.mp4",
          "format": "video/mp4",
          "source": "Agent 3"
        },
        {
          "path": "broadcast-engine/output/manifest.json",
          "format": "json",
          "source": "Agent 2"
        }
      ],
      "outputs": [
        {
          "path": "agent5-video-assembler/output/broadcast-final.mp4",
          "format": "video/mp4",
          "consumed_by": [
            "agent6"
          ]
        },
        {
          "path": "agent5-video-assembler/output/assembly-report.json",
          "format": "json",
          "consumed_by": [
            "agent6"
          ]
        }
      ]
    },
    "agent6": {
      "name": "Final Reviewer",
      "domain": "D:\\claude_demo\u0007gent6-final-review",
      "role": "Final quality review, pipeline completeness check, package final output",
      "inputs": [
        {
          "path": "agent5-video-assembler/output/broadcast-final.mp4",
          "format": "video/mp4",
          "source": "Agent 5"
        },
        {
          "path": "agent5-video-assembler/output/assembly-report.json",
          "format": "json",
          "source": "Agent 5"
        },
        {
          "path": "broadcast-engine/output/manifest.json",
          "format": "json",
          "source": "Agent 2"
        }
      ],
      "outputs": [
        {
          "path": "agent6-final-review/output/final-review-report.md",
          "format": "markdown",
          "consumed_by": [
            "user"
          ]
        },
        {
          "path": "agent6-final-review/output/final-review.json",
          "format": "json",
          "consumed_by": [
            "user"
          ]
        },
        {
          "path": "final-output/",
          "format": "directory",
          "consumed_by": [
            "user"
          ]
        }
      ]
    }
  },
  "data_contracts": {
    "horizon_item": {
      "description": "A single enriched news item from Horizon",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "source_type": {
          "type": "string",
          "enum": [
            "hackernews",
            "rss",
            "reddit",
            "github",
            "twitter"
          ]
        },
        "title": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "content": {
          "type": "string"
        },
        "author": {
          "type": "string"
        },
        "published_at": {
          "type": "string",
          "format": "datetime"
        },
        "ai_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 10
        },
        "ai_summary": {
          "type": "string"
        },
        "ai_tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "metadata": {
          "type": "object",
          "properties": {
            "title_zh": {
              "type": "string"
            },
            "title_en": {
              "type": "string"
            },
            "detailed_summary_zh": {
              "type": "string"
            },
            "detailed_summary_en": {
              "type": "string"
            },
            "sources": {
              "type": "array"
            }
          }
        }
      },
      "required": [
        "id",
        "source_type",
        "title",
        "url",
        "ai_score"
      ]
    },
    "horizon_enriched_file": {
      "description": "The enriched JSON file containing multiple news items",
      "type": "array",
      "items": {
        "$ref": "#/data_contracts/horizon_item"
      }
    },
    "broadcast_script": {
      "description": "A generated broadcast script in Markdown format",
      "type": "string",
      "format": "markdown",
      "metadata": {
        "date": {
          "type": "string"
        },
        "language": {
          "type": "string",
          "enum": [
            "zh",
            "en"
          ]
        },
        "item_count": {
          "type": "integer"
        },
        "estimated_duration_seconds": {
          "type": "integer"
        }
      }
    },
    "remotion_video": {
      "description": "Rendered video output from Remotion",
      "type": "file",
      "format": "video/mp4",
      "resolution": {
        "width": 1920,
        "height": 1080
      },
      "fps": 30,
      "codec": "h264"
    },
    "review_report": {
      "description": "Aesthetic review report for the video",
      "type": "object",
      "properties": {
        "score": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "issues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "suggestions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "verdict": {
          "type": "string",
          "enum": [
            "PASS",
            "FAIL"
          ]
        }
      },
      "required": [
        "score",
        "verdict"
      ]
    },
    "assembly_report": {
      "description": "Agent 5 assembly report with verification results and ffmpeg concat output",
      "type": "object",
      "properties": {
        "verdict": {
          "type": "string",
          "enum": [
            "PASS",
            "FAIL"
          ]
        },
        "validation": {
          "type": "object"
        },
        "concat": {
          "type": "object"
        }
      }
    },
    "final_review_report": {
      "description": "Agent 6 final review report",
      "type": "object",
      "properties": {
        "verdict": {
          "type": "string",
          "enum": [
            "PASS",
            "FAIL"
          ]
        },
        "stages": {
          "type": "object"
        },
        "reason": {
          "type": "string"
        }
      }
    }
  },
  "output_structure": {
    "final_output": {
      "path": "D:\\claude_demo\\final-output",
      "structure": {
        "video": "Final assembled broadcast video (broadcast-final.mp4)",
        "reports": "Assembly report + final review report",
        "artifacts": "manifest.json + voiceover files"
      }
    }
  }
}