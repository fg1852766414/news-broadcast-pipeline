{
  "name": "remotion-product",
  "version": "1.0.0",
  "description": "Remotion video project - News broadcast style video with seendance effects",
  "scripts": {
    "start": "remotion studio",
    "build:news": "remotion render src/index.ts NewsBroadcast output/broadcast.mp4 --browser-executable=\"D:\\chrome-headless-shell-win64\\chrome-headless-shell.exe\"",
    "build:manifest": "remotion render src/index.ts ManifestVideo output/broadcast.mp4 --browser-executable=\"D:\\chrome-headless-shell-win64\\chrome-headless-shell.exe\"",
    "build:showcase": "remotion render src/index.ts EffectShowcase output/showcase.mp4 --browser-executable=\"D:\\chrome-headless-shell-win64\\chrome-headless-shell.exe\"",
    "build:opening": "remotion render src/index.ts CinematicOpening output/opening.mp4 --browser-executable=\"D:\\chrome-headless-shell-win64\\chrome-headless-shell.exe\"",
    "preview": "remotion preview src/index.ts"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "@remotion/gif": "^4.0.475",
    "@remotion/google-fonts": "^4.0.475",
    "@remotion/light-leaks": "^4.0.475",
    "@remotion/lottie": "^4.0.475",
    "@remotion/motion-blur": "^4.0.475",
    "@remotion/preload": "^4.0.475",
    "@remotion/renderer": "^4.0.0",
    "@remotion/transitions": "^4.0.475",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "typescript": "^5.5.0"
  }
}
